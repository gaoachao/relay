# Runtime
HOST=127.0.0.1
PORT=8787
NODE_ENV=development

# Server-side only. Never expose this value to iOS, Android, or the website.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_OUTPUT_TOKENS=2048
REQUEST_BODY_LIMIT_BYTES=65536

# auto uses OpenAI when a key exists and the deterministic mock otherwise.
AGENT_PROVIDER=auto
AGENT_ENABLE_MOCK_FALLBACK=true
MOCK_STREAM_DELAY_MS=24

# Comma-separated exact origins. Requests without Origin (native clients) are allowed.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
