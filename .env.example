# The Agent runs in mock mode when OPENAI_API_KEY is empty.
HOST=127.0.0.1
PORT=8787
NODE_ENV=development

# Server-side only. Never expose this value to iOS, Android, or the website.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_OUTPUT_TOKENS=2048
REQUEST_BODY_LIMIT_BYTES=65536

AGENT_PROVIDER=auto
AGENT_ENABLE_MOCK_FALLBACK=true
MOCK_STREAM_DELAY_MS=24
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
